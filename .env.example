# Copy to `.env` and fill in. The real `.env` is gitignored — never commit it.
# Every value below is a default; delete a line to keep the default.
# Full reference: docs/DEPLOY.md (env table). Ops add-ons: docs/OPERATIONS.md.

# ─── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# Model per role. Unset = gpt-4o-mini. `extract` is the only vision role (it
# transcribes scanned/math PDF pages).
LLM_EXTRACT=gpt-4o-mini
LLM_ROUTER=gpt-4o-mini
LLM_GENERATE=gpt-4o-mini
LLM_GRADE=gpt-4o-mini
LLM_JUDGE=gpt-4o-mini

# Swap every non-vision role to another provider with one switch.
#   groq   -> free hosted tier.  Needs: uv sync --extra groq  + GROQ_API_KEY
#   ollama -> fully local, zero cost. Needs: uv sync --extra local + `ollama serve`
# A per-role prefix beats this switch entirely, e.g. LLM_GENERATE=ollama:llama3.1
# `extract` always falls back to OpenAI: neither provider does vision.
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_VISION_MODEL=llama3.2-vision   # local vision is weak on math; see docs/RUN-LOCAL.md

# ─── Storage ──────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                       # required for Qdrant Cloud
# QDRANT_COLLECTION=courses

# SQLite is fine locally. It is NOT fine in production: a container's filesystem
# is ephemeral, so this file — and every account in it — is wiped on the next
# rebuild or sleep/wake. Deployments must point at a managed Postgres.
DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql+psycopg://user:pass@host/db?sslmode=require

# ─── Retrieval ────────────────────────────────────────────────────────────────
# The refusal floor: nothing scoring above this is retrieved, and the tutor
# refuses instead of guessing. Calibrated empirically — see eval/calibrate.py.
# SIMILARITY_THRESHOLD=0.35
# EMBEDDING_MODEL=BAAI/bge-m3

# Opt-in retrieval boosters, all off by default. Each widens recall while the
# refusal guard stays intact. The reranker needs the `ingestion` extra; hybrid
# needs a collection ingested with `--sparse`.
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_CANDIDATES=20
# HYBRID_RETRIEVAL=false
# MULTI_QUERY=false
# HYDE=false
# NEIGHBOR_EXPANSION=false

# ─── API ──────────────────────────────────────────────────────────────────────
# Browser origins allowed to call the API. The web app cannot reach the API
# without its exact origin listed here.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# true = every data endpoint needs a valid JWT, and each account sees only its
# own material. Required for any public deployment.
# REQUIRE_AUTH=false

# Signs user JWTs. The app REFUSES TO BOOT with this placeholder (or anything
# under 16 chars) once REQUIRE_AUTH=true — anyone who knows it can forge tokens.
# JWT_SECRET=dev-insecure-change-me
# JWT_EXPIRE_MINUTES=60

# Optional shared-secret gate, independent of user auth: clients must then send a
# matching X-API-Key header. /health stays open.
# API_KEY=

# Per-IP cap. 0 means AUTO, not off: unthrottled locally, but 60/min as soon as
# REQUIRE_AUTH=true, so a public deployment is never accidentally unlimited.
# RATE_LIMIT_PER_MINUTE=0

# MAX_UPLOAD_MB=100
# ENABLE_HSTS=false                     # only meaningful behind TLS
# LOG_LEVEL=INFO

# ─── Optional add-ons ─────────────────────────────────────────────────────────
# Tracing. Activates only when both keys are set. Needs the `obs` extra.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Cost guards. Cache: "" | memory | sqlite. Budget: 0 = no cap.
# LLM_CACHE=memory
# LLM_BUDGET_TOKENS=0

# Durable storage for uploaded originals (Cloudflare R2, S3-compatible). Without
# it, uploads land on the container's ephemeral disk and "view original file"
# 404s after a redeploy — the course itself stays indexed and answerable. Set all
# four, or none. Needs the `storage` extra. See docs/DEPLOY.md.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
