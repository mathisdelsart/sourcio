# Copy to `.env` and fill in. The real `.env` is gitignored.

# LLM per role (get_llm factory). Defaults to gpt-4o-mini when unset.
LLM_EXTRACT=gpt-4o-mini
LLM_ROUTER=gpt-4o-mini
LLM_GENERATE=gpt-4o-mini
LLM_GRADE=gpt-4o-mini
LLM_JUDGE=gpt-4o-mini

# Provider API key
OPENAI_API_KEY=

# Fully local, zero-cost runs via Ollama (optional). Two ways to switch:
#   1. Per role, with a provider prefix that wins over everything else, e.g.
#      LLM_EXPLAIN=ollama:llama3.1
#   2. Globally, flip every role to Ollama with one switch (model ids then come
#      from the defaults below or from any LLM_<ROLE> you set). Requires the
#      `local` extra: `uv sync --extra local`, plus a running `ollama serve`.
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# Default Ollama models used when LLM_PROVIDER=ollama and a role has no override.
# The extract role needs a multimodal model to transcribe slides; local vision
# quality on math/LaTeX is lower than gpt-4o (see docs/LOCAL.md).
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_VISION_MODEL=llama3.2-vision

# Free-tier hosted LLM via Groq (optional, zero-cost public deployment). Flip
# every non-vision role to a Groq-hosted model with one switch. Requires the
# `groq` extra (`uv sync --extra groq`) and a GROQ_API_KEY. The vision `extract`
# role falls back to OpenAI (Groq has no vision), but ingestion is offline-only.
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Infra
QDRANT_URL=http://localhost:6333
DATABASE_URL=sqlite:///./app.db

# Comma-separated browser origins allowed to call the API (CORS). Defaults to
# local dev (http://localhost:3000) so the web/ frontend works locally; set this
# to your deployed frontend URL (e.g. https://your-app.vercel.app) in production.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cross-encoder reranker (optional, opt-in precision boost; no re-ingestion).
# "" disables it (dense retrieval unchanged). Set a model name to enable: more
# candidates are fetched from Qdrant, rescored by the cross-encoder, then the
# top-k are kept. Runs locally and needs the `ingestion` extra.
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_CANDIDATES=20

# Observability (optional, opt-in). Tracing activates only when the public and
# secret keys are set. Requires the `obs` extra: `uv sync --extra obs`.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# LLM response cache (optional, opt-in cost saver). "" disables it, "memory"
# uses an in-process cache, "sqlite" persists to disk across runs. The sqlite
# backend needs `langchain_community`; without it, it falls back to memory.
# LLM_CACHE=memory

# Token budget cap (optional, opt-in guard). 0 disables it; a positive value
# stops the LLM factory once accumulated token usage exceeds the cap.
# LLM_BUDGET_TOKENS=0

# API-key authentication (optional, opt-in). "" leaves the API fully open; a
# non-empty value requires clients to send a matching `X-API-Key` header on the
# /ask, /exercise, /grade and /history endpoints. /health is always open.
# API_KEY=

# In-process rate limiting (optional, opt-in). 0 disables it (the default, so
# the API is unthrottled); a positive value caps each client IP to that many
# requests per rolling 60s window, returning HTTP 429 with a Retry-After header
# once exceeded. Per-process only (one Uvicorn worker); use an edge limiter for
# multi-replica deployments.
# RATE_LIMIT_PER_MINUTE=0

# HTTP Strict-Transport-Security header (optional). Off by default because HSTS
# only makes sense behind HTTPS/TLS. Enable it only when serving over TLS. The
# other security headers (nosniff, frame-options, referrer-policy, etc.) are
# always sent.
# ENABLE_HSTS=false

# Structured logging level (optional). The API emits one JSON object per line
# (timestamp, level, logger, message, and the per-request X-Request-ID). Use a
# standard level name; an unknown value falls back to INFO. Default INFO.
# LOG_LEVEL=INFO

# User authentication (register / login / me). The secret signs user JWTs
# (HS256); it MUST be set to a long random value in production — the default is
# an insecure local-only placeholder. JWT_EXPIRE_MINUTES sets the token
# lifetime. Independent of API_KEY above; the two guards coexist.
# JWT_SECRET=dev-insecure-change-me
# JWT_EXPIRE_MINUTES=60

# Durable object storage for uploaded course-file originals (optional,
# Cloudflare R2 — S3-compatible). Local disk (the default) works fine for local
# dev but is EPHEMERAL on the production container (Hugging Face Spaces): every
# redeploy/sleep-wake wipes it, silently losing "view original file". Set all
# four below to switch to R2, which survives restarts; leaving any of them
# empty keeps the local-disk-only fallback unchanged. Requires the `storage`
# extra (`uv sync --extra storage`). See docs/DEPLOY-API.md for the exact
# Cloudflare dashboard setup steps.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
